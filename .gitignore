docs/*.xlsx
*.pdf

# venv e lock local do backend
backend/.venv/

# Playwright
frontend/test-results/
frontend/playwright-report/

# Subpastas de docs tambem podem ter dados sensiveis (repo publico!)
docs/**/*.docx
docs/**/*.pdf
docs/**/*.doc
docs/**/*.xlsx
docs/prints-teste-disc/
docs/green-house-logo*.png
# Listas internas (CNPJs, lotacoes, dados da empresa) — repo publico
docs/postos_para_importar.txt
docs/**/*.txt
docs/Lota*
docs/**/*.PDF
# Regra guarda-chuva (repo PUBLICO): ignora TODA a pasta docs/ — material de
# trabalho do RH com dados sensiveis (oficios com CNPJ/contrato, planilha de
# colaboradores, modelos .html/.doc). So o planejamento (markdown, sem dado
# pessoal) e versionado. Qualquer arquivo novo em docs/ ja nasce ignorado.
docs/*
!docs/planejamento/
!docs/planejamento/**

# Ferramentas locais BMAD
_bmad/
