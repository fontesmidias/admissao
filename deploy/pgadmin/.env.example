# ============================================================
# pgAdmin 4 — copie para deploy/pgadmin/.env e preencha.
# NUNCA commitar o .env (só este .example). Contém a senha de
# acesso ao administrador do banco — trate como segredo.
# ============================================================

# --- Login do pgAdmin (a conta que abre a interface web) ---
PGADMIN_DEFAULT_EMAIL=admin@greenhousedf.com.br
PGADMIN_DEFAULT_PASSWORD=troque-por-uma-senha-forte

# --- Porta local (só loopback; o Nginx faz o proxy externo) ---
PGADMIN_PORT=5050

# --- Rede Docker do stack principal (confirme com `docker network ls`) ---
# Prefixo = nome do diretório de deploy. Padrão "deploy_internal".
STACK_NETWORK=deploy_internal

# ------------------------------------------------------------
# Dados de conexão ao Postgres (NÃO vão em variável — você cadastra
# o servidor DENTRO do pgAdmin, na 1ª vez). Guardados aqui só como
# LEMBRETE do que preencher na tela "Register > Server":
#   Host name/address:  db          (nome do serviço na rede deploy_internal)
#   Port:               5432
#   Maintenance DB:     admissao    (= POSTGRES_DB do .env do app)
#   Username:           admissao    (= POSTGRES_USER do .env do app)
#   Password:           <POSTGRES_PASSWORD do .env do app>
# ------------------------------------------------------------
